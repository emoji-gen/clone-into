{
  "name": "@emoji-gen/clone-into",
  "version": "0.3.2",
  "description": "Wrapper function for Firefox's cloneInto",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "format:check": "prettier . --check",
    "format:fix": "prettier . --write",
    "test": "run-p test:types test:unit format:check",
    "test:types": "tsc --noEmit",
    "test:unit": "rstest",
    "build": "tsup src/index.ts --dts --format esm,cjs",
    "clean": "rimraf dist",
    "prepack": "run-s clean build"
  },
  "devDependencies": {
    "@rstest/core": "^0.10.6",
    "@swc/core": "^1.15.43",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.9.3",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "author": {
    "name": "Pine Mizune",
    "email": "pinemz@gmail.com",
    "url": "https://github.com/pine"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emoji-gen/clone-into.git"
  },
  "bugs": {
    "url": "https://github.com/emoji-gen/clone-into/issues"
  },
  "homepage": "https://github.com/emoji-gen/clone-into",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
